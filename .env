# ═══════════════════════════════════════════════
#  SFAAM NEWS — Environment Variables
#  Apni keys yahan paste karo
# ═══════════════════════════════════════════════

# ── WORLD NEWS Keys ──
GROQ_KEY_WORLD=yahan_groq_key_1
GEMINI_KEY_WORLD=yahan_gemini_key_1

# ── USA NEWS Keys ──
GROQ_KEY_USA=yahan_groq_key_2
GEMINI_KEY_USA=yahan_gemini_key_2

# ── UK NEWS Keys ──
GROQ_KEY_UK=yahan_groq_key_3
GEMINI_KEY_UK=yahan_gemini_key_3

# ── PAKISTAN NEWS Keys ──
GROQ_KEY_PAKISTAN=yahan_groq_key_4
GEMINI_KEY_PAKISTAN=yahan_gemini_key_4

# ── INDIA NEWS Keys ──
GROQ_KEY_INDIA=yahan_groq_key_5
GEMINI_KEY_INDIA=yahan_gemini_key_5

# ── Database ──
DATABASE_URL=sqlite:///./sfaam.db

# ── Server ──
HOST=0.0.0.0
PORT=8000

# ── Settings ──
SCRAPE_INTERVAL=5
DELETE_AFTER_DAYS=30
SITE_URL=https://sfaamnews.com
